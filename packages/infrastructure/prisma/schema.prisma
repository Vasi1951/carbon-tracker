datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Activity {
  id          String   @id
  userId      String
  category    String
  amount      Float
  unit        String
  date        DateTime
  description String

  @@index([userId, date])
  @@index([category])
}

model EmissionFactor {
  id          String @id @default(uuid())
  category    String
  co2ePerUnit Float
  source      String
  region      String
  year        Int

  @@unique([category, region, year])
}

model UserGoal {
  id            String   @id
  userId        String
  targetKgCO2e  Float
  timeframe     String
  createdAt     DateTime @default(now())
}
